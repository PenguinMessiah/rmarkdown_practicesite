title: "practiceNEO1"
## %>% can be seen as "And then..." It doesn't work on this online one LOL
fungang %>%
select(char, age) %>%
filter(age < 30) %>%
arrange(age)
char <- c("Kris", "Susie", "Ralsei")
## Variables are assigned through the arrow <-
## c combines any values into a compact vector list (In this case combines the names of the characters into a list, with age and ATKbeing other lists.)
## data.frame takes those vector lists and turns them all into combined data that can be viewed!
char <- c("Kris", "Susie", "Ralsei")
age <- c(18, 21, 999)
ATK <- c("S", "R", "S")
fungang <- data.frame(char, age, ATK)
## fungang$char
## the $ character isolates a single list from the data frame.
## The [square brackets] can be used to only look at a specific part of a data set, inputting numbers beyond the result in a NULL output. You can use a colon to view more of a specific row
fungang[1,1:3]
## This function looks at our data frame, specifically the age of the fun gang, and then prints the list whose age is below 20 (In this case it's only Kris)
fungang[fungang$age<20, 1:2]
## Variables are assigned through the arrow <-
## c combines any values into a compact vector list (In this case combines the names of the characters into a list, with age and ATKbeing other lists.)
